@model IEnumerable<samsungweb.Models.Product>

    <!-- BANNER -->
    <section class="ss-hero-banner">
        <div class="ss-banner-content">
            <p class="ss-banner-desc">
                Ưu đãi đổi x10 điểm Samsung rewards cho<br>
                màu độc quyền. Áp dụng đến 16.03.2026
            </p>
        
            <div class="ss-banner-buttons">
                <a asp-controller="Home" asp-action="Details" asp-route-id="10" class="btn-link">Tìm hiểu thêm</a>
                <a asp-controller="Home" asp-action="Buy" asp-route-id="10" class="btn-outline">Mua</a>
            </div>
        </div>
        </section>
  

    <!-- DANH SÁCH SẢN PHẨM 1 -->
    <section class="ss-product-grid-section">
        <div class="ss-product-grid">
        
            @* Bắt đầu vòng lặp: Có bao nhiêu sản phẩm Nổi bật, nó sẽ đẻ ra bấy nhiêu khối *@
        @foreach (var item in Model)
        {
            <div class="ss-product-card">
                <h3 class="ss-product-title">@item.Name</h3>
                
                <div class="ss-product-image">
                    <img src="~/images/@item.ImageUrl" alt="@item.Name">
                    
                    <a asp-controller="Home" asp-action="Buy" asp-route-id="@item.Id" class="btn btn-dark rounded-pill px-4" style="position: absolute; bottom: 20px; z-index: 10;">
                        Mua
                    </a>
                </div>
            </div>
        }

                        </div>
                    </section>


                      <!-- VIDEO / TV -->
                        <section class="ss-video-section">
                            <video class="ss-bg-video" id="aiTvVideo" autoplay loop muted playsinline>
                                <source src="/video/videomp4.webm" type="video/mp4">
                                    </video>

                                    <div class="ss-video-content">
                                        <div class="ss-text-block">
                                            <h2 class="ss-video-title">2025 AI TVs</h2>
                                            <p class="ss-video-desc">Khám phá những AI TVs mới</p>
            
                                            <div class="ss-video-actions">
                                                <a href="#" class="btn-link-dark">Tìm hiểu thêm</a>
                                                <a href="#" class="btn-outline-dark">Xem tất cả</a>
                                            </div>
                                        </div>
                                    </div>

                                    <button class="ss-video-control" id="playPauseBtn" onclick="togglePlay()">
                                        <i class="bi bi-pause-circle"></i>
                                    </button>
                                </section>

                    @section Scripts {
                        <script>
                                function togglePlay() {
                                    var video = document.getElementById("aiTvVideo");
                                    var btnIcon = document.querySelector("#playPauseBtn i");

                                    if (video.paused) {
                                        video.play();
                                        // Đổi icon thành nút Pause
                                        btnIcon.className = "bi bi-pause-circle";
                                    } else {
                                        video.pause();
                                        // Đổi icon thành nút Play
                                        btnIcon.className = "bi bi-play-circle";
                                    }
                                }
                        </script>
                    }
    <!-- DANH SÁCH SẢN PHẨM 2 -->
    <section class="ss-product-grid-section">
        <div class="ss-product-grid">
        
            @* Bắt đầu vòng lặp: Có bao nhiêu sản phẩm Nổi bật, nó sẽ đẻ ra bấy nhiêu khối *@
        @if (ViewBag.TvProducts != null)
        {
            foreach (var item in (IEnumerable<samsungweb.Models.Product>)ViewBag.TvProducts) 
            {
                <div class="ss-product-card">
                    <h3 class="ss-product-title">@item.Name</h3>
                    <div class="ss-product-image">
                        <img src="~/images/@item.ImageUrl" alt="@item.Name" />
                        
                        <a asp-controller="Home" asp-action="Buy" asp-route-id="@item.Id" class="btn btn-dark rounded-pill px-4" style="position: absolute; bottom: 20px; z-index: 10;">
                            Mua
                        </a>
                    </div>
                </div>
            }
        }

                        </div>
     </section>
    <div class="container mt-5">
    <h1 class="title mb-4">Khám phá những câu chuyện</h1>

    <div class="row g-4">
        <!-- Item 1 -->
        <div class="col-md-3">
            <div class="card custom-card">
                <img src="~/images/h1.jpg" class="card-img-top" />
                <div class="card-body">
                    <p class="card-text">Phát lại Unpacked</p>
                </div>
            </div>
        </div>

        <!-- Item 2 -->
        <div class="col-md-3">
            <div class="card custom-card">
                <img src="~/images/h2.jpg" class="card-img-top" />
                <div class="card-body">
                    <p class="card-text">Galaxy AI</p>
                </div>
            </div>
        </div>

        <!-- Item 3 -->
        <div class="col-md-3">
            <div class="card custom-card">
                <img src="~/images/h3.jpg" class="card-img-top" />
                <div class="card-body">
                    <p class="card-text">One UI</p>
                </div>
            </div>
        </div>

        <!-- Item 4 -->
        <div class="col-md-3">
            <div class="card custom-card">
                <img src="~/images/h4.jpg" class="card-img-top" />
                <div class="card-body">
                    <p class="card-text">Chuyển sang Galaxy</p>
                </div>
            </div>
        </div>
    </div>
    </div>


@section Styles {
    <link rel="stylesheet" href="~/css/components/product-card.css" />
    <link rel="stylesheet" href="~/css/pages/home.css" />
    <style>
        /* 1. Thanh tìm kiếm nền xám nhạt (Chuẩn bài cho Header nền trắng) */
        header form, .ss-header form {
            background-color: #f1f3f4 !important; 
            border: 1px solid #e0e0e0 !important;
            border-radius: 30px !important;
            backdrop-filter: none !important; /* Tắt kính mờ vì không cần thiết nữa */
        }
        
        /* 2. Sửa màu chữ ô input thành MÀU ĐEN */
        header form input, .ss-header form input {
            background-color: transparent !important;
            color: #000000 !important; 
            border: none !important;
            box-shadow: none !important;
        }
        header form input::placeholder, .ss-header form input::placeholder {
            color: #5f6368 !important; /* Chữ placeholder xám đậm cho dễ đọc */
        }

        /* 3. Nút kính lúp MÀU ĐEN */
        header form button, .ss-header form button {
            background-color: transparent !important;
            border: none !important;
        }
        header form button i, header form button svg,
        .ss-header form button i, .ss-header form button svg {
            color: #000000 !important;
            fill: #000000 !important;
        }
    </style>
}