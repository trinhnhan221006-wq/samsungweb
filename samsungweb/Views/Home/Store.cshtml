@model IEnumerable<samsungweb.Models.Product>
@{
    ViewData["Title"] = "Cửa hàng Samsung";
    Layout = "_Layout";

    // Ép kiểu để tránh lỗi 'dynamic' và lỗi gạch chân đỏ
    var currentCat = ViewBag.CurrentCategory as samsungweb.Models.Category;
}

@section Styles {
    <link rel="stylesheet" href="~/css/components/product-card.css" />
    <link rel="stylesheet" href="~/css/pages/store.css" />
    <link rel="stylesheet" href="~/css/components/scroll-top.css" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
}

@functions {
    string GetIcon(string name)
    {
        return name switch
        {
            "Di động" => "bi-phone",
            "TV & AV" => "bi-tv",
            "Gia dụng" => "bi-washer",
            "IT" => "bi-laptop",
            "Thiết bị đeo" => "bi-watch",
            "Phụ kiện" => "bi-headphones",
            _ => "bi-grid"
        };
    }
}

<div class="store-page-wrapper">
    
    @* --- PHẦN 1: NỬA TRÊN (NỀN TRẮNG) --- *@
    <section class="store-header-section">
        <h1 class="store-page-title text-center"
            style="font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; font-weight: 800; font-size: 3rem; letter-spacing: -1px; margin-bottom: 2rem;">
            Lựa chọn tối ưu chuẩn sống của bạn
        </h1>

        <div class="category-menu text-center mb-5">
            
            <div class="store-category-filters">
                @* Nút Mới & Nổi bật *@
                <a href="/Home/Store" class="filter-box @(currentCat == null ? "active" : "")">
                    <i class="bi bi-star"></i>
                    <span>Mới & Nổi bật</span>
                </a>

                @if (ViewBag.Categories != null)
                {
                    // Dùng tên biến 'catItem' để tránh lỗi trùng tên 'parent' [cite: 52]
                    foreach (var catItem in (List<samsungweb.Models.Category>)ViewBag.Categories)
                    {
                        var isSelected = currentCat != null && (currentCat.Id == catItem.Id || currentCat.ParentId == catItem.Id);
                        
                        <a href="/Home/Store?categoryId=@catItem.Id" class="filter-box @(isSelected ? "active" : "")">
                            <i class="bi @GetIcon(catItem.Name)"></i>
                            <span>@catItem.Name</span>
                        </a>
                    }
                }
            </div>

            @* HIỂN THỊ DANH MỤC CON (GALAXY S, GALAXY A...) *@
            @if (currentCat != null)
            {
                var subList = currentCat.ParentId == null ? currentCat.SubCategories : currentCat.ParentCategory?.SubCategories;

                if (subList != null && subList.Count > 0) // Dùng Count > 0 thay vì Any() để tránh lỗi [cite: 58]
                {
                    <div class="d-flex justify-content-center gap-4 mt-4 border-bottom pb-2">
                        @foreach (var sub in subList)
                        {
                            var isSubSelected = currentCat.Id == sub.Id;
                            <a href="/Home/Store?categoryId=@sub.Id"
                                   class="text-decoration-none @(isSubSelected ? "text-dark fw-bold border-bottom border-dark border-2 pb-1" : "text-secondary fw-semibold")"
                                   style="font-size: 1.1rem;">
                                @sub.Name
                            </a>
                        }
                    </div>
                }
            }
        </div>
    </section>
    @* --- PHẦN 2: NỬA DƯỚI (NỀN XÁM) --- *@
    <section class="store-products-section">
        
        @* Cấu trúc thanh cuộn ngang (Carousel) *@
        <div class="store-products-carousel" id="productCarousel">
            @if (Model.Any())
            {
                foreach (var sp in Model)
                {
                    <div class="store-product-card">
                        <h3 class="store-card-title">@sp.Name</h3>
                        
                        <div class="product-image-container">
                            <img src="~/images/@sp.ImageUrl" alt="@sp.Name">
    
                                <button class="btn quick-view-btn" data-id="@sp.Id">
                                    Hãy khám phá thiết bị
                                </button>
                            </div>

                            <div class="store-card-price">
                                @sp.Price.ToString("N0") VND
                            </div>

                            <a asp-action="Buy" asp-route-id="@sp.Id" class="btn btn-dark rounded-pill mt-3 fw-bold py-2">
                                Mua ngay
                            </a>
                        </div>
                    }
                }
            else
                {
                    <div class="w-100 text-center py-5">
                        <p class="text-muted fs-4">Hiện chưa có sản phẩm nào.</p>
                    </div>
                }
            </div>

            @* Thanh tiến trình và Nút điều hướng *@
            <div class="store-carousel-controls">
                <div class="carousel-progress-track">
                    <div class="carousel-progress-bar" id="progressBar" style="width: 20%;"></div>
                </div>
                <div class="carousel-nav-buttons">
                    <button class="nav-btn" onclick="scrollCarousel(-1)"><i class="bi bi-chevron-left"></i></button>
                    <button class="nav-btn" onclick="scrollCarousel(1)"><i class="bi bi-chevron-right"></i></button>
                </div>
            </div>
        </section>

    </div>

    @* JS nhỏ để xử lý nút bấm cuộn ngang *@
    @section Scripts {
        <script>
            function scrollCarousel(direction) {
                const carousel = document.getElementById('productCarousel');
                const scrollAmount = 340; // Độ rộng thẻ + gap
                carousel.scrollBy({ left: direction * scrollAmount, behavior: 'smooth' });
            }
        // ==========================================
        // JS MỚI: GIAI ĐOẠN 4 - AJAX QUICK VIEW MODAL
        // ==========================================
        document.addEventListener('DOMContentLoaded', function () {
            
            // 1. Lấy tất cả các nút có class "quick-view-btn"
            const quickViewBtns = document.querySelectorAll('.quick-view-btn');

            // 2. Gắn "tai nghe" sự kiện Click cho từng nút
            quickViewBtns.forEach(btn => {
                btn.addEventListener('click', function (e) {
                    e.preventDefault(); // Ngăn trình duyệt nhảy trang
                    
                    // Lấy ID của sản phẩm từ thuộc tính data-id trên nút
                    const productId = this.getAttribute('data-id'); 

                    // 3. Gọi AJAX (Fetch API) về Controller để lấy dữ liệu
                    fetch(`/Home/GetProductDetails?id=${productId}`)
                        .then(response => {
                            if (!response.ok) throw new Error('Lỗi mạng!');
                            return response.json(); // Biến dữ liệu thô thành JSON
                        })
                        .then(data => {
                                    // 1. Nhét dữ liệu text như bình thường
            document.getElementById('modalProductName').textContent = data.name;
            document.getElementById('modalProductPrice').textContent = data.price;
            document.getElementById('modalProductImage').src = `/images/${data.imageUrl}`;
            // Phải dùng đúng chữ screenSize, cameraInfo, chipset, battery như trong file HomeController.cs
            document.getElementById('modalScreenSize').textContent = data.screenSize || 'Đang cập nhật';
            document.getElementById('modalCameraInfo').textContent = data.cameraInfo || 'Đang cập nhật';
            document.getElementById('modalChipset').textContent = data.chipset || 'Đang cập nhật';
            document.getElementById('modalBattery').textContent = data.battery || 'Đang cập nhật';
            document.getElementById('modalBuyBtn').href = '/Home/Buy/' + data.id;

            // 2. Lấy các phần tử nhãn và icon để thay đổi
            const mLabel1 = document.getElementById('modalLabel1');
            const mLabel2 = document.getElementById('modalLabel2');
            const mLabel3 = document.getElementById('modalLabel3');
            const mLabel4 = document.getElementById('modalLabel4');

            const mIcon1 = document.getElementById('modalIcon1');
            const mIcon2 = document.getElementById('modalIcon2');
            const mIcon3 = document.getElementById('modalIcon3');
            const mIcon4 = document.getElementById('modalIcon4');

            // 3. Logic thay đổi Nhãn và Icon theo CategoryId
            switch (String(data.categoryId)) {
                case "4": // TV & AV
                    mLabel1.textContent = "Màn hình"; mIcon1.className = "bi bi-display fs-4 text-secondary mt-1";
                    mLabel2.textContent = "Độ phân giải"; mIcon2.className = "bi bi-aspect-ratio fs-4 text-secondary mt-1";
                    mLabel3.textContent = "Bộ xử lý hình ảnh"; mIcon3.className = "bi bi-cpu fs-4 text-secondary mt-1";
                    mLabel4.textContent = "Công suất tiêu thụ"; mIcon4.className = "bi bi-lightning-charge fs-4 text-secondary mt-1";
                    break;
                case "5": // Gia dụng (Tủ lạnh)
                    mLabel1.textContent = "Dung tích tổng"; mIcon1.className = "bi bi-box-seam fs-4 text-secondary mt-1";
                    mLabel2.textContent = "Công nghệ làm lạnh"; mIcon2.className = "bi bi-snow fs-4 text-secondary mt-1";
                    mLabel3.textContent = "Kháng khuẩn"; mIcon3.className = "bi bi-shield-check fs-4 text-secondary mt-1";
                    mLabel4.textContent = "Kích thước"; mIcon4.className = "bi bi-arrows-fullscreen fs-4 text-secondary mt-1";
                    break;
                case "8": // Phụ kiện (Ốp lưng)
                    mLabel1.textContent = "Chất liệu"; mIcon1.className = "bi bi-layers fs-4 text-secondary mt-1";
                    mLabel2.textContent = "Dòng máy"; mIcon2.className = "bi bi-phone-vibrate fs-4 text-secondary mt-1";
                    mLabel3.textContent = "Màu sắc"; mIcon3.className = "bi bi-palette fs-4 text-secondary mt-1";
                    mLabel4.textContent = "Tính năng"; mIcon4.className = "bi bi-stars fs-4 text-secondary mt-1";
                    break;
                default: // Mặc định là Điện thoại (ID 3) hoặc các loại khác
                    mLabel1.textContent = "Màn hình"; mIcon1.className = "bi bi-display fs-4 text-secondary mt-1";
                    mLabel2.textContent = "Camera"; mIcon2.className = "bi bi-camera fs-4 text-secondary mt-1";
                    mLabel3.textContent = "Chip xử lý"; mIcon3.className = "bi bi-cpu fs-4 text-secondary mt-1";
                    mLabel4.textContent = "Pin & Sạc"; mIcon4.className = "bi bi-battery-charging fs-4 text-secondary mt-1";
            }

            // 4. Bật Modal
            var quickViewModal = new bootstrap.Modal(document.getElementById('quickViewModal'));
            quickViewModal.show();
                        })
                        .catch(error => {
                            console.error('Có lỗi xảy ra:', error);
                            alert('Không thể tải thông số sản phẩm lúc này. Vui lòng thử lại!');
                        });
                });
            });
        });

        </script>
    }



    <div class="modal fade" id="quickViewModal" tabindex="-1" aria-labelledby="quickViewModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-xl">
            <div class="modal-content rounded-4 border-0 shadow-lg">
                <div class="modal-header border-0 pb-0">
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
            
                <div class="modal-body pt-0 px-4 px-md-5 pb-5">
                    <div class="row g-5">
                    
                        <div class="col-md-5 d-flex flex-column align-items-center justify-content-center">
                            <img id="modalProductImage" src="" class="img-fluid mb-4" alt="Product Image" style="max-height: 450px; object-fit: contain;">
                            <div class="d-flex gap-2">
                                <span class="rounded-circle bg-dark" style="width:10px; height:10px;"></span>
                                <span class="rounded-circle bg-secondary" style="width:10px; height:10px;"></span>
                                <span class="rounded-circle bg-light border" style="width:10px; height:10px;"></span>
                            </div>
                        </div>

                        <div class="col-md-7">
                        
                            <div class="d-flex justify-content-between align-items-start border-bottom pb-4 mb-4">
                                <div>
                                    <h2 id="modalProductName" class="fw-bold mb-2" style="font-size: 2rem;">Tên Sản Phẩm</h2>
                                    <p id="modalProductPrice" class="fw-bold mb-0" style="color: #0071e3; font-size: 1.2rem;">Giá tiền</p>
                                </div>
                                <a href="#" id="modalBuyBtn" class="btn text-white rounded-pill px-4 py-2 fw-bold" style="background-color: #0071e3; font-size: 0.95rem;">Mua</a>
                            </div>

                            <div class="d-flex flex-column gap-4" style="font-size: 0.95rem; color: #333;">
    
                                <div class="d-flex align-items-start gap-3">
                                    <i id="modalIcon1" class="bi bi-display fs-4 text-secondary mt-1"></i>
                                    <div>
                                        <strong id="modalLabel1">Màn hình</strong>
                                        <span id="modalScreenSize" class="d-block text-muted mt-1" style="line-height: 1.5;">Đang cập nhật...</span>
                                    </div>
                                </div>
    
                                <div class="d-flex align-items-start gap-3">
                                    <i id="modalIcon2" class="bi bi-camera fs-4 text-secondary mt-1"></i>
                                    <div>
                                        <strong id="modalLabel2">Camera</strong>
                                        <span id="modalCameraInfo" class="d-block text-muted mt-1" style="line-height: 1.5;">Đang cập nhật...</span>
                                    </div>
                                </div>
    
                                <div class="d-flex align-items-start gap-3">
                                    <i id="modalIcon3" class="bi bi-cpu fs-4 text-secondary mt-1"></i>
                                    <div>
                                        <strong id="modalLabel3">Chip xử lý</strong>
                                        <span id="modalChipset" class="d-block text-muted mt-1" style="line-height: 1.5;">Đang cập nhật...</span>
                                    </div>
                                </div>
    
                                <div class="d-flex align-items-start gap-3">
                                    <i id="modalIcon4" class="bi bi-battery-charging fs-4 text-secondary mt-1"></i>
                                    <div>
                                        <strong id="modalLabel4">Pin & Sạc</strong>
                                        <span id="modalBattery" class="d-block text-muted mt-1" style="line-height: 1.5;">Đang cập nhật...</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="row mt-5 pt-4 border-top" style="font-size: 0.85rem; color: #555;">
                        <div class="col-md-4 d-flex gap-2 mb-3 mb-md-0">
                            <i class="bi bi-box-seam text-success fs-5"></i>
                            <span><strong class="text-dark">Giao hàng miễn phí</strong><br>Áp dụng tận nơi trên toàn quốc.</span>
                        </div>
                        <div class="col-md-4 d-flex gap-2 mb-3 mb-md-0">
                            <i class="bi bi-shield-check text-primary fs-5"></i>
                            <span><strong class="text-dark">Bảo hành chính hãng</strong><br>Cam kết 12 tháng tại các trung tâm.</span>
                        </div>
                        <div class="col-md-4 d-flex gap-2">
                            <i class="bi bi-arrow-repeat text-warning fs-5"></i>
                            <span><strong class="text-dark">Thu cũ đổi mới</strong><br>Trợ giá lên đời cao nhất thị trường.</span>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>

    <section class="buy-section container mt-5">
        <h2 class="buy-title mb-4">Mua trực tiếp - Nhận ngay ưu đãi</h2>

        <div class="row mt-4 g-4">

            <!-- Card 1 -->
            <div class="col-md-3">
                <div class="buy-card">
                    <i class="bi bi-arrow-repeat icon"></i>
                    <h5>Thu cũ đổi mới</h5>
                    <p>An tâm hơn với chế độ bảo hành chính hãng</p>
                    <a href="#" class="btn-buy">Tìm hiểu thêm</a>
                </div>
            </div>

            <!-- Card 2 -->
            <div class="col-md-3">
                <div class="buy-card2">
                    <i class="bi bi-credit-card icon"></i>
                    <h5>Tài chính linh hoạt</h5>
                    <p>Mua trước trả sau với lãi suất từ 0%</p>
                    <a href="#" class="btn-buy">Tìm hiểu thêm</a>
                </div>
            </div>

            <!-- Card 3 -->
            <div class="col-md-3">
                <div class="buy-card">
                    <i class="bi bi-truck icon"></i>
                    <h5>Miễn phí giao hàng</h5>
                    <p>Tận hưởng giao hàng tận nơi miễn phí</p>
                    <a href="#" class="btn-buy">Tìm hiểu thêm</a>
                </div>
            </div>

            <!-- Card 4 -->
            <div class="col-md-3">
                <div class="buy-card">
                    <i class="bi bi-shield-check icon"></i>            
                    <h5>Ưu đãi độc quyền</h5>
                    <p>Nhận voucher và quà tặng khi mua trực tiếp</p>
                    <a href="#" class="btn-buy">Tìm hiểu thêm</a>
                </div>
            </div>

        </div>
    </section>
    <div class="container">
        <h2 class="title1">Giúp tôi lựa chọn</h2>

        <div class="card-wrapper">
            <div class="card-item">
                <h4>Tìm chiếc tủ lạnh phù hợp với bạn</h4>
                <button class="btn">Tìm hiểu thêm</button>
                <img src="~/images/tulanh-Picsart-BackgroundRemover.jpg" />
            </div>

            <div class="card-item2">
                <h4>Tìm chiếc TV phù hợp với bạn</h4>
                <button class="btn">Tìm hiểu thêm</button>
                <img src="~/images/tivi-Picsart-BackgroundRemover.jpg" />
            </div>

            <div class="card-item">
                <h4>Tìm chiếc điện thoại phù hợp với bạn</h4>
                <button class="btn">Tìm hiểu thêm</button>
                <img src="~/images/dt-Picsart-BackgroundRemover.jpg"/>
            </div>

            <div class="card-item">
                <h4>Tìm chiếc máy giặt phù hợp với bạn</h4>
                <button class="btn">Tìm hiểu thêm</button>
                <img src="~/images/maygiat-Picsart-BackgroundRemover.jpg" />
            </div>
        </div>
    </div>
    <div class="offer-container">
        <h2 class="offer-title">Ưu đãi đặc biệt</h2>

        <div class="offer-list">

            <!-- Card 1 -->
            <div class="offer-card">
                <img src="~/images/student.jpg" />
                <h4>Dành cho sinh viên & giáo dục</h4>
                <a href="#">Tìm hiểu thêm</a>
            </div>

            <!-- Card 2 -->
            <div class="offer-card">
                <img src="~/images/special-stores-partner-employees.jpg" />
                <h4>Dành cho nhân viên đối tác</h4>
                <a href="#">Tìm hiểu thêm</a>
            </div>

            <!-- Card 3 -->
            <div class="offer-card">
                <img src="~/images/b9d96d62-909e-484e-b3e6-c032c229d0d1.jpg" />
                <h4>Dành cho chính phủ</h4>
                <a href="#">Tìm hiểu thêm</a>
            </div>

        </div>
    </div>
    <a href="#" class="scroll-top-btn" id="scrollTopBtn" title="Lên đầu trang">
        <i class="bi bi-arrow-up"></i>
    </a>