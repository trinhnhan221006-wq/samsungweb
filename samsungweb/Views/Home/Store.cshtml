                <a href="#">Tìm hiểu thêm</a>
            </div>

            <!-- Card 2 -->
            <div class="offer-card">
                <img src="~/images/special-stores-partner-employees.jpg" />
                <h4>Dành cho nhân viên đối tác</h4>
                <a href="#">Tìm hiểu thêm</a>
            </div>

            <!-- Card 3 -->
            <div class="offer-card">
                <img src="~/images/b9d96d62-909e-484e-b3e6-c032c229d0d1.jpg" />
