@model samsungweb.Models.Order

@{
    ViewData["Title"] = "Thanh toán";
    Layout = "_Layout";
    // Ép kiểu dữ liệu từ ViewBag trả về List để xài
    var cart = ViewBag.Cart as List<samsungweb.Models.CartItem>;
    var total = ViewBag.Total != null ? (decimal)ViewBag.Total : 0;
}

<div class="container mt-5 pb-5 mb-5">
    <h2 class="fw-bold mb-4">Thanh toán đơn hàng</h2>
    
    <div class="row">
        <div class="col-lg-7 mb-4">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <h4 class="mb-4">Thông tin giao hàng</h4>
                    
                    <form asp-controller="Checkout" asp-action="ProcessCheckout" method="post">
                        
                        <div class="mb-3">
                            <label class="form-label fw-bold">Họ và Tên <span class="text-danger">*</span></label>
                            <input asp-for="CustomerName" class="form-control form-control-lg" placeholder="Nhập họ và tên đầy đủ" required />
                            <span asp-validation-for="CustomerName" class="text-danger"></span>
                        </div>
                        
                        <div class="mb-3">
                            <label class="form-label fw-bold">Số điện thoại <span class="text-danger">*</span></label>
                            <input asp-for="PhoneNumber" type="tel" class="form-control form-control-lg" placeholder="Ví dụ: 0912345678" required />
                            <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                        </div>
                        
                        <div class="mb-3">
                            <label class="form-label fw-bold">Email nhận hóa đơn <span class="text-danger">*</span></label>
                            <input asp-for="Email" type="email" class="form-control form-control-lg" placeholder="Ví dụ: hotro@gmail.com" required />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Địa chỉ giao hàng <span class="text-danger">*</span></label>
                            <textarea asp-for="Address" class="form-control form-control-lg" rows="3" placeholder="Nhập số nhà, tên đường, phường/xã, quận/huyện..." required></textarea>
                            <span asp-validation-for="Address" class="text-danger"></span>
                        </div>
                        
                        <div class="mb-4">
                            <label class="form-label fw-bold">Ghi chú thêm (Tùy chọn)</label>
                            <textarea asp-for="Note" class="form-control" rows="2" placeholder="Ví dụ: Giao giờ hành chính..."></textarea>
                        </div>
                        
                        <button type="submit" class="btn btn-dark btn-lg w-100 rounded-pill fw-bold shadow-sm">Xác nhận Đặt hàng</button>
                    </form>
                </div>
            </div>
        </div>
        
        <div class="col-lg-5">
            <div class="card border-0 shadow-sm rounded-4 bg-light">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-4">Tóm tắt đơn hàng</h5>
                    
                    <div class="mb-4">
                        @if (cart != null)
                        {
                            foreach (var item in cart)
                            {
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <div class="d-flex align-items-center">
                                        <img src="~/images/@item.ImageUrl" style="width: 50px; height: 50px; object-fit: contain;" class="rounded me-3 border bg-white" alt="@item.ProductName" />
                                        <div>
                                            <h6 class="mb-0 fw-bold">@item.ProductName</h6>
                                            <small class="text-muted">@item.SelectedCapacity | @item.SelectedColor</small>
                                            <div class="text-muted small">SL: @item.Quantity</div>
                                        </div>
                                    </div>
                                    <span class="fw-bold">@item.Total.ToString("N0") đ</span>
                                </div>
                            }
                        }
                    </div>
                    
                    <hr class="border-secondary mb-4">
                    
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Tạm tính</span>
                        <span class="fw-bold">@total.ToString("N0") đ</span>
                    </div>
                    <div class="d-flex justify-content-between mb-3">
                        <span class="text-muted">Phí giao hàng</span>
                        <span class="text-success fw-bold">Miễn phí</span>
                    </div>
                    
                    <div class="d-flex justify-content-between align-items-center mt-4 pt-3 border-top border-secondary">
                        <span class="fs-5 fw-bold">Tổng thanh toán</span>
                        <span class="fs-3 fw-bold text-primary">@total.ToString("N0") đ</span>
                    </div>
                </div>
            </div>
        </div>
        
    </div>
</div>