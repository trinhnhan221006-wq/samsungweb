@{
    ViewData["Title"] = "Đặt hàng thành công";
    Layout = "_Layout";
}

<div class="container mt-5 text-center d-flex flex-column justify-content-center align-items-center" style="min-height: 60vh;">
    <i class="bi bi-check-circle-fill text-success" style="font-size: 100px;"></i>
    <h1 class="fw-bold mt-4 text-success">Đặt hàng thành công!</h1>
    <p class="text-muted fs-5 mt-2">Cảm ơn bạn đã tin tưởng và mua sắm tại hệ thống của chúng tôi.</p>
    <p class="fs-6">Đơn hàng của bạn đã được ghi nhận vào hệ thống. Chúng tôi sẽ sớm liên hệ qua số điện thoại để xác nhận và giao hàng.</p>
    
    <div class="mt-4">
        <a asp-controller="Home" asp-action="Store" class="btn btn-dark rounded-pill px-5 py-3 fw-bold fs-5 shadow">Tiếp tục mua sắm</a>
    </div>
</div>