@model Microsoft.AspNetCore.Identity.IdentityUser
@{
    ViewData["Title"] = "Cấp Quyền";
    Layout = "_LayoutAdmin";
}

<div class="container-fluid mt-4">
    <h3 class="mb-4 fw-bold">🛡️ Cấp quyền cho: <span class="text-primary">@Model.Email</span></h3>
    
    <div class="card shadow-sm" style="max-width: 500px;">
        <div class="card-body">
            <form asp-action="AssignRole" method="post">
                <input type="hidden" name="userId" value="@Model.Id" />
                
                <div class="form-group mb-4">
                    <label class="fw-bold mb-2">Chọn chức vụ muốn cấp:</label>
                    <select name="roleName" class="form-control form-select" asp-items="ViewBag.Roles">
                        <option value="">-- Click để chọn chức vụ --</option>
                    </select>
                </div>
                
                <button type="submit" class="btn btn-success fw-bold">✔️ Xác nhận cấp quyền</button>
                <a asp-action="Index" class="btn btn-secondary">Hủy bỏ</a>
            </form>
        </div>
    </div>
</div>