@model samsungweb.Models.Product

@{
    ViewData["Title"] = "Create";
    Layout = "_LayoutAdmin";
}

@section Styles {
    <style>
        .ss-header {
            position: relative !important;
            background-color: #ffffff !important;
            border-bottom: 1px solid #ebebeb;
        }
        .ss-header a, .ss-header .ss-search-bar i { color: #000000 !important; }
        
        /* Đẩy nội dung khung Quản trị xích xuống cho dễ nhìn */
        .admin-container {
            padding: 50px 5%;
            min-height: 60vh;
        }
    </style>
}

<div class="admin-container">
    <h2>Quản lý Sản phẩm</h2>
    
<h4>Product</h4>
<hr />
<div class="row">
    <div class="col-md-6"> 
        <form asp-action="Create" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            
            <div class="form-group mb-3">
                <label asp-for="Name" class="control-label fw-bold"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            
            <div class="form-group mb-3">
                <label asp-for="Price" class="control-label fw-bold"></label>
                <input asp-for="Price" class="form-control" />
                <span asp-validation-for="Price" class="text-danger"></span>
            </div>
            
            <div class="form-group mb-3">
                <label class="control-label fw-bold">Hình ảnh sản phẩm</label>
                <input type="file" name="frontImage" class="form-control" accept="image/*" />
            </div>

            <hr />
            <h5 class="text-primary">Thông số kỹ thuật chi tiết (Tùy chọn)</h5>
            
            <div class="form-group mb-3">
                <label asp-for="ScreenSize" class="control-label fw-bold"></label>
                <input asp-for="ScreenSize" class="form-control" placeholder="VD: 6.8 inch Dynamic AMOLED 2X..." />
                <span asp-validation-for="ScreenSize" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="CameraInfo" class="control-label fw-bold"></label>
                <textarea asp-for="CameraInfo" class="form-control" rows="3" placeholder="VD: Hệ thống camera pro 200MP..."></textarea>
                <span asp-validation-for="CameraInfo" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Chipset" class="control-label fw-bold"></label>
                <input asp-for="Chipset" class="form-control" placeholder="VD: Snapdragon 8 Gen 4..." />
                <span asp-validation-for="Chipset" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Battery" class="control-label fw-bold"></label>
                <input asp-for="Battery" class="form-control" placeholder="VD: 5000 mAh, sạc nhanh 45W..." />
                <span asp-validation-for="Battery" class="text-danger"></span>
            </div>
            <hr />
            <div class="form-group mb-3">
                <label asp-for="CategoryId" class="control-label fw-bold">Danh mục sản phẩm</label>
                <select asp-for="CategoryId" class="form-control" asp-items="ViewBag.CategoryId">
                    <option value="">-- Chọn danh mục --</option>
                </select>
                <span asp-validation-for="CategoryId" class="text-danger"></span>
            </div>
            
            <div class="form-group mt-4">
                <input type="submit" value="Create" class="btn btn-primary px-4" />
                <a asp-action="Index" class="btn btn-secondary ms-2">Back to List</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
</div>