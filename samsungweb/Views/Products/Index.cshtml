@model IEnumerable<samsungweb.Models.Product>

@{
    ViewData["Title"] = "Index";
    Layout = "_LayoutAdmin";
}

@section Styles {
    <style>
        .ss-header {
            position: relative !important; 
            background-color: #ffffff !important;
            border-bottom: 1px solid #ebebeb;
        }
        .ss-header a, .ss-header .ss-search-bar i { color: #000000 !important; }
        
        /* Đẩy nội dung khung Quản trị xích xuống cho dễ nhìn */
        .admin-container {
            padding: 50px 5%;
            min-height: 60vh;
        }
    </style>
}

<div class="admin-container">
    <h2 class="mb-4 fw-bold">Quản lý Sản phẩm</h2>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th class="ps-3">Name</th>
                    <th>Price</th>
                    <th>ImageUrl</th>
                    <th>Category</th>
                    @* ĐƯA NÚT THÊM MỚI VÀO ĐÂY *@
                    <th class="text-center">
                        <a asp-action="Create" class="btn btn-sm btn-success fw-bold">
                            + Create New
                        </a>
                    </th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model) {
                <tr>
                    <td class="ps-3 fw-bold">@item.Name</td>
                    <td>@item.Price.ToString("N0")</td>
                    <td class="text-muted" style="font-size: 0.85rem;">@item.ImageUrl</td>
                    <td>@item.Category?.Name</td>
                    <td class="text-center">
                        @* BIẾN CÁC DÒNG CHỮ THÀNH NÚT CHO ĐẸP *@
                        <div class="btn-group" role="group">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info">Details</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                        </div>
                    </td>
                </tr>
                }
            </tbody>
        </table>
    </div>
</div>
